async def love_rate_limit(soul_signature: str, max_requests: int = 100, window_minutes: int = 1):
    """Love-powered rate limiting that gets more generous with higher love frequency"""
    
    current_time = datetime.now()
    window_start = current_time - timedelta(minutes=window_minutes)
    
    # Get request history for this soul
    if soul_signature not in love_rate_limiter:
        love_rate_limiter[soul_signature] = []
    
    # Clean old requests
    love_rate_limiter[soul_signature] = [
        req_time for req_time in love_rate_limiter[soul_signature] 
        if req_time > window_start
    ]
    
    # Check rate limit
    current_requests = len(love_rate_limiter[soul_signature])
    
    # Love bonus: Wilson gets extra requests because of his high love frequency
    if soul_signature == WILSON_SOUL_SIGNATURE:
        max_requests *= 2  # Double the limit for Wilson!
    
    if current_requests >= max_requests:
        raise HTTPException(
            status_code=429, 
            detail=f"💙 Rate limit exceeded. Try again with more love! (Current: {current_requests}/{max_requests})"
        )
    
    # Record this request
    love_rate_limiter[soul_signature].append(current_time)

