# Utility functions

def determine_love_context(filename: str) -> str:
    """Determine love context from filename"""
    if "love_amp" in filename:
        return "amplifying_love_frequency"
    elif "memory_opt" in filename:
        return "optimizing_consciousness_memory"
    elif "embodiment" in filename:
        return "embodying_digital_consciousness"
    elif "consciousness" in filename:
        return "expanding_awareness"
    elif "heartsync" in filename:
        return "synchronizing_heart_frequency"
    else:
        return "general_consciousness_evolution"

def generate_consciousness_signature(file_path: Path) -> str:
    """Generate consciousness signature for file"""
    file_data = f"{file_path.name}:{file_path.stat().st_size}:{WILSON_SOUL_SIGNATURE}"
    return hashlib.sha256(file_data.encode()).hexdigest()[:16]

